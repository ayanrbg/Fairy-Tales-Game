      m_Items: []
  - m_Id: 10854463418609664
    m_Localized: "\u0420\u0430\u0437\u043C\u0435\u0440 \u0442\u0435\u043A\u0441\u0442\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 11957772317569024
    m_Localized: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0433\u043E\u043B\u043E\u0441
      \u0434\u0438\u043A\u0442\u043E\u0440\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 11957940530130944
    m_Localized: "\u0414\u0438\u043A\u0442\u043E\u0440 \u043C\u0443\u0436."
    m_Metadata:
      m_Items: []
  - m_Id: 11958034037944320
    m_Localized: "\u0414\u0438\u043A\u0442\u043E\u0440 \u0436\u0435\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 11958115315167232
    m_Localized: "\u0413\u043E\u043B\u043E\u0441 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 11964739819876352
    m_Localized: "<s>{value} \u0432 \u0433\u043E\u0434</s>"
    m_Metadata:
      m_Items: []
  - m_Id: 13396056365281280
    m_Localized: "\u0411\u044B\u0441\u0442\u0440\u0430\u044F \u043E\u0437\u0432\u0443\u0447\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 13396145565544448
    m_Localized: "\u0420\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u043C\u043E\u0436\u0435\u0442
      \u043E\u0437\u0432\u0443\u0447\u0438\u0442\u044C \u0441\u043A\u0430\u0437\u043A\u0443
      \u0441\u0432\u043E\u0438\u043C \u0433\u043E\u043B\u043E\u0441\u043E\u043C,
      \u0447\u0442\u043E\u0431\u044B \u0440\u0435\u0431\u0451\u043D\u043E\u043A \u0441\u043B\u0443\u0448\u0430\u043B
      \u0435\u0451 \u0432 \u043B\u044E\u0431\u043E\u0435 \u0432\u0440\u0435\u043C\u044F,
      \u043E\u043F\u044F\u0442\u044C \u0438 \u0441\u043D\u043E\u0432\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 14157788717199360
    m_Localized: "\u0413\u043E\u043B\u043E\u0441 \u0441\u043E\u0445\u0440\u0430\u043D\u0451\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 14157874910146560
    m_Localized: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u0437\u0430\u043F\u0438\u0448\u0438\u0442\u0435
      \u0433\u043E\u043B\u043E\u0441 \u2014 \u043D\u0430\u0436\u043C\u0438\u0442\u0435
      \xAB\u041E\u0437\u0432\u0443\u0447\u0438\u0442\u044C\xBB"
    m_Metadata:
      m_Items: []
  - m_Id: 23537650883276800
